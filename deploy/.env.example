# Copy to .env next to docker-compose.yml and fill in.

# 32-byte key that encrypts every stored Azure DevOps PAT at rest.
# Generate: openssl rand -base64 32
# BACK IT UP — losing it makes every stored PAT unrecoverable.
MASTER_KEY=

# Optional: hard-pin the public origin (otherwise derived from proxy headers).
# PUBLIC_URL=https://ado-mcp.example.com
